{
  "project_name": "Carnet Digital Municipal",
  "version": "1.0.0",
  "context": {
    "target_audience": "Ciudadanos de municipios",
    "clients": "Ayuntamientos",
    "primary_use_case": "Control de acceso y validación de reservas en instalaciones municipales (ej. polideportivos)",
    "environment": "Módulo integrado dentro de la Web App existente (sección 'Mi Perfil')"
  },
  "tech_stack": {
    "frontend": "Mithril.js",
    "styling": "CSS Inline",
    "database": "MongoDB",
    "qr_generation": "Librería JS ligera (por definir, ej. qrcode.js)"
  },
  "functional_requirements": [
    "El usuario debe poder acceder a su carnet desde la sección 'Mi Perfil' sin un login adicional.",
    "El carnet debe mostrar visualmente: Nombre del usuario, DNI/ID, Estado de la cuota/reserva, y Logotipo del Ayuntamiento.",
    "El carnet debe generar un Código QR dinámico para ser escaneado en el control de acceso.",
    "El sistema de escaneo debe validar el QR contra la base de datos para confirmar si el usuario tiene acceso permitido.",
    "El usuario debe tener la opción de exportar su carnet a Apple Wallet y Google Wallet."
  ],
  "technical_requirements": [
    "El QR debe renderizarse siempre sobre fondo blanco para garantizar la lectura de escáneres ópticos.",
    "El componente del carnet en Mithril.js debe ser responsive y adaptarse a la pantalla de cualquier smartphone.",
    "La base de datos (MongoDB) debe tener una colección 'carnets' vinculada al ObjectId del usuario.",
    "El QR debe contener un token seguro o identificador único, no datos personales en texto plano."
  ],
  "ui_ux_specifications": {
    "card_design": "Estilo tarjeta de crédito/identificación, colores parametrizables por Ayuntamiento.",
    "visual_cues": "Uso de badges (ej. verde/rojo) para identificar rápidamente el estado del usuario ('Al día', 'Pendiente').",
    "wallet_buttons": "Botones nativos/simulados claros para la exportación a Passbook/Wallets."
  },
  "data_model_draft": {
    "collection": "carnets",
    "fields": {
      "userId": "ObjectId (Referencia al ciudadano)",
      "ayuntamientoId": "ObjectId (Referencia a la entidad)",
      "carnetNumber": "String (Identificador visible único)",
      "status": "String (active, suspended, expired)",
      "issuedDate": "Date",
      "qrToken": "String (Token JWT o Hash para el QR)"
    }
  }
}